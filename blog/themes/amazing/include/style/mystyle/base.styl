$family-code ?= "Source Code Pro", "JetBrains Mono", monospace, "Microsoft YaHei"
$family-sans-serif1 ?= "Roboto Slab", "PingFang SC", "Microsoft JhengHei", "Microsoft YaHei", sans-serif !important

body, button, input, select, textarea {
  font-family: $family-sans-serif1
}

body {
  min-height: 100vh;
  position: relative;
  background: radial-gradient(circle at 16% 14%, rgba(30, 234, 255, 0.20), transparent 22%),
    radial-gradient(circle at 86% 10%, rgba(68, 182, 255, 0.16), transparent 24%),
    radial-gradient(circle at 50% 100%, rgba(15, 120, 144, 0.10), transparent 28%),
    linear-gradient(180deg, #041018 0%, #061620 42%, #02070b 100%);
}

body:before,
body:after {
  content: '';
  position: fixed;
  inset: 0;
  z-index: -1;
  pointer-events: none;
}

body:before {
  background: linear-gradient(90deg, transparent 0, transparent calc(100% - 1px), rgba(30, 234, 255, 0.05) calc(100% - 1px)),
    linear-gradient(transparent 0, transparent calc(100% - 1px), rgba(30, 234, 255, 0.035) calc(100% - 1px));
  background-size: 64px 64px;
  mask-image: linear-gradient(180deg, rgba(0, 0, 0, .88), transparent 96%);
}

body:after {
  background: radial-gradient(circle at center, rgba(0, 0, 0, 0) 0, rgba(0, 0, 0, .38) 100%);
  opacity: .9;
}

a {
  transition: color .2s ease;
}

a:hover {
  color: #82f8ff;
}

.navbar,
.footer {
  backdrop-filter: blur(16px);
}

.navbar {
  border-bottom: 1px solid rgba(30, 234, 255, 0.14);
}

.footer {
  border-top: 1px solid rgba(30, 234, 255, 0.14);
}

.card,
.footer,
.navbar {
  box-shadow: 0 18px 54px rgba(0, 0, 0, 0.24);
}

.card {
  border: 1px solid rgba(30, 234, 255, 0.14);
  background: linear-gradient(180deg, rgba(7, 18, 24, 0.94), rgba(4, 11, 16, 0.92));
}

.card .title,
.article .title,
.menu-label,
.footer,
.navbar {
  letter-spacing: .02em;
}

.menu-label {
  text-transform: uppercase;
  letter-spacing: .08em;
}

.card-content {
  background: transparent;
}

.article .content h1,
.article .content h2,
.article .content h3,
.article .content h4 {
  letter-spacing: .02em;
}

.article .content blockquote {
  background-color: rgba(30, 234, 255, 0.08);
  border-left: 3px solid #1eeaff;
  color: #d9fbff;
}

.article .content pre,
.article .content code {
  font-family: $family-code;
}

.article .content pre {
  background: rgba(5, 10, 15, 0.94);
  border: 1px solid rgba(30, 234, 255, 0.14);
}

.tag:not(body) {
  background-color: rgba(30, 234, 255, 0.10);
  color: #d6fbff;
}

.menu-list a.is-active,
.menu-list a:hover,
.pagination-link.is-current {
  border-color: rgba(30, 234, 255, 0.28);
}

.navbar-end #night-nav {
  display: none;
}

.card-image img {
  object-fit: cover;
}

.navbar-item.is-active,
.navbar-item:hover,
.navbar-item:focus {
  color: #efffff !important;
  text-shadow: 0 0 18px rgba(30, 234, 255, 0.18);
}

.navbar-logo img,
.footer-logo img {
  border-radius: 14px;
  box-shadow: 0 0 18px rgba(30, 234, 255, 0.18);
}

.navbar-logo img {
  width: 2.35rem;
  height: 2.35rem;
  object-fit: cover;
}

.avatar {
  border: 1px solid rgba(30, 234, 255, 0.24);
  box-shadow: 0 0 22px rgba(30, 234, 255, 0.18);
}

.level-item .title,
.card .title {
  color: #efffff;
}

.heading,
.menu-label,
.article-meta {
  color: #83c9d4 !important;
}

.level-item.tag,
.index-categories,
.index-tags {
  background: rgba(30, 234, 255, 0.09) !important;
  border: 1px solid rgba(30, 234, 255, 0.14);
  color: #d6fbff !important;
}

.button.is-primary,
.article-more.button {
  background: linear-gradient(135deg, rgba(18, 225, 255, 0.94), rgba(94, 244, 255, 0.88)) !important;
  border-color: transparent !important;
  color: #031018 !important;
  font-weight: 700;
  box-shadow: 0 8px 24px rgba(18, 225, 255, 0.18);
}

.button.is-primary:hover,
.article-more.button:hover {
  transform: translateY(-1px);
  box-shadow: 0 12px 28px rgba(18, 225, 255, 0.22);
}

.menu-list a,
.pagination-link,
.pagination-next,
.pagination-previous {
  background: rgba(7, 16, 22, 0.28);
}

.home-empty {
  overflow: hidden;
}

.home-empty-shell {
  min-height: 64vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 3.6rem 2rem;
}

.home-empty-mark {
  width: min(220px, 44vw);
  margin-bottom: 1.5rem;
  filter: drop-shadow(0 0 28px rgba(30, 234, 255, 0.18));
}

.home-empty-kicker {
  margin-bottom: 0.85rem;
  color: #83c9d4;
  font-size: 0.82rem;
  letter-spacing: 0.26em;
  text-transform: uppercase;
}

.home-empty-title {
  margin-bottom: 0.9rem !important;
}

.home-empty-copy {
  max-width: 38rem;
  margin: 0 auto;
  color: #c6edf2;
  line-height: 1.85;
}

.home-empty-actions {
  margin-top: 1.6rem;
}

.post-copyright {
  border-left: 3px solid rgba(138, 214, 255, 0.4);
}

// 自定义图片样式
.img-x {
  position: relative;
  overflow-y: hidden;
  height: 100%;
  white-space: nowrap;
  a {
    box-sizing: border-box;
    text-align: center;
    position: relative;
    display: inline-block;
    padding: 10px 10px;
    vertical-align: top;
    height: 100%;
    width: 40%;
  }
}

.img-y {
  position: relative;
  overflow-y: hidden;
  height: 100%;
  white-space: nowrap;
  a {
    box-sizing: border-box;
    text-align: center;
    position: relative;
    display: inline-block;
    padding: 10px 10px;
    vertical-align: top;
    height: 100%;
    width: 30%;
  }
}

.article hr {
  background-color: #6190e8;
  margin-top: -0.8rem;
  margin-bottom: 1rem;
  box-shadow: 1px 2px 8px #000;
}

.index-category-tag hr {
  background-color: #f5f5f5;
  margin-top: .3rem;
  margin-bottom: .5rem;
  box-shadow: unset;
}

.friend-title-item {
  font-weight: bold;
  text-align: center;
}

// 友链
.friend-card-item {
  width: 32%;
  border-radius: 2px;
  color: #4a4a4a;
  padding: 0.5rem;
  display: inline-block;
  margin: 5px;
  margin-top: 15px;
  .text-desc {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .ava {
    width: 5rem !important;
    height: 5rem !important;
    margin: 0 !important;
    margin-right: 0.2em !important;
    border-radius: 40px;
  }
  img {
    float: left;
    transition: all 0.5s ease-in;
    -webkit-transition: all 0.5s ease-in;
    -moz-transition: all 0.5s ease-in;
    -o-transition: all 0.5s ease-in;
  }
  img:hover {
    transform: rotate(360deg);
    -webkit-transform: rotate(360deg);
    -moz-transform: rotate(360deg);
    -o-transform: rotate(360deg);
    -ms-transform: rotate(360deg);
  }
  &:hover {
    transform: scale(0.995);
    box-shadow: 0 2px 6px 0 rgba(0, 0, 0, 0.12), 0 0 6px 0 rgba(0, 0, 0, 0.04);
  }
}

.content blockquote {
  background-color: #f5f5f5;
  border-left: 3px solid #6190e8;
  padding: 1em 1em;
  overflow: auto;
}

// about timeline
.time-axis-main {
  width: 90%;
  margin: 30px auto;
  .time-axis {
    margin: 0;
    padding: 0;
    position: relative;
  }

  .time-axis:before {
    content: '';
    position: absolute;
    left: 93px;
    top: 15px;
    width: 1px;
    height: 100%;
    background-color: #E4E4E4;
  }

  .time-axis-item {
    list-style: none;
    padding-left: 150px;
    position: relative;
    line-height: 45px;
    font-size: 14px;
    color: #141414;
  }

  .time-axis-date {
    position: absolute;
    left: -1.9%;
    top: 0;
    color: #3273dc;
    font-style: italic;
    font-weight: bold;
  }

  .time-axis-title {
    background-color: whitesmoke;
    border-left: 3px solid #6190e8;
    padding: 0.8em 1.0em;
    font-weight: bold;
    line-height: 25px;
  }

  .time-axis-achievement {
    background-color: whitesmoke;
    border-left: 3px solid #e89b44;
    padding: 0em 1.0em;
    font-style: italic;
    margin-bottom: 30px;
  }

  .time-axis-date span {
    position: absolute;
    right: -25px;
    top: 35%;
    display: block;
    width: 13px;
    height: 13px;
    border: 1px solid #ccc;
    border-radius: 100%;
    background-color: #fff;
  }

  .time-axis-date span:after {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
    width: 7px;
    height: 7px;
    margin: auto;
    background-color: #ccc;
    border: 1px solid #ccc;
    border-radius: 100%;
  }

  .time-axis-item:first-child .time-axis-date span {
    border-color: #48BEB2;
  }

  .time-axis-item:first-child .time-axis-date span:after {
    background-color: #48BEB2;
    border-color: #48BEB2;
  }
}

.music-container {
  .video-player .fa-video-camera:before {
    content: "\f03d";
  }

  .video-player .fa-music:before {
    content: "\f001";
  }
  #musicarea {
    margin: 20px auto;
    width: 500px;
  }
  .music-player {
    .d-title {
      margin-bottom: 20px;
      font-size: 2rem;
      font-weight: 700;
      text-align: center;
    }
  }
}

.video-player {

  .d-title {
    margin-bottom: 20px;
    font-size: 2rem;
    font-weight: 700;
    text-align: center;
  }

  .fa {
    display: inline-block;
    font: normal normal normal 14px / 1 FontAwesome;
    font-size: inherit;
    text-rendering: auto;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  .hits {
    text-align: center;
    font-size: 13px;
    color: #cd0411
  }

  #video-list {
    overflow-y: auto;
    height: 300px;
    blockquote {
      font-size: 13px;
      text-align: center;
      border-right: 3px solid #6190e8;
    }
  }
}

.text-center {
  text-align: center;
}

.markdown-body {
  font-family: $family-sans-serif !important;
  img {
    max-width: 30% !important;
  }
}

#hitokoto {
  text-align: center;
  cursor: pointer;
  padding: 1rem;
}

.text-tips {
