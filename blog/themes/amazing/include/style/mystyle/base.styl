    position: relative;
    display: inline-block;
    padding: 10px 10px;
    vertical-align: top;
    height: 100%;
    width: 40%;
  }
}

.img-y {
  position: relative;
  overflow-y: hidden;
  height: 100%;
  white-space: nowrap;
  a {
    box-sizing: border-box;
    text-align: center;
    position: relative;
    display: inline-block;
    padding: 10px 10px;
    vertical-align: top;
    height: 100%;
    width: 30%;
  }
}

.article hr {
  background-color: #6190e8;
  margin-top: -0.8rem;
  margin-bottom: 1rem;
  box-shadow: 1px 2px 8px #000;
}

.index-category-tag hr {
