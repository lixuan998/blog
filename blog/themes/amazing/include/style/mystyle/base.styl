$family-code ?= "IBM Plex Mono", "JetBrains Mono", monospace, "Microsoft YaHei"
$family-sans-serif1 ?= "IBM Plex Sans", "PingFang SC", "Microsoft JhengHei", "Microsoft YaHei", sans-serif !important

body, button, input, select, textarea {
  font-family: $family-sans-serif1
}

body > .footer,
body > .navbar,
body > .section {
  opacity: 1 !important;
}

body {
  min-height: 100vh;
  position: relative;
  background: radial-gradient(circle at 14% 18%, rgba(126, 169, 191, 0.12), transparent 24%),
    radial-gradient(circle at 88% 12%, rgba(210, 180, 140, 0.08), transparent 20%),
    linear-gradient(180deg, #081016 0%, #0a1218 44%, #05080b 100%);
}

body:before,
body:after {
  content: '';
  position: fixed;
  inset: 0;
  z-index: -1;
  pointer-events: none;
}

body:before {
  background: linear-gradient(90deg, transparent 0, transparent calc(100% - 1px), rgba(126, 169, 191, 0.04) calc(100% - 1px)),
    linear-gradient(transparent 0, transparent calc(100% - 1px), rgba(126, 169, 191, 0.025) calc(100% - 1px));
  background-size: 64px 64px;
  mask-image: linear-gradient(180deg, rgba(0, 0, 0, .88), transparent 96%);
}

body:after {
  background: repeating-linear-gradient(180deg, transparent 0, transparent 22px, rgba(255, 255, 255, 0.02) 22px, rgba(255, 255, 255, 0.02) 23px);
  opacity: .45;
}

a {
  transition: color .2s ease;
}

a:hover {
  color: #d2b48c;
}

.navbar,
.footer {
  backdrop-filter: blur(16px);
}

.navbar {
  border-bottom: 1px solid rgba(126, 169, 191, 0.14);
}

.footer {
  border-top: 1px solid rgba(126, 169, 191, 0.14);
}

.card,
.footer,
.navbar {
  box-shadow: 0 18px 54px rgba(0, 0, 0, 0.24);
}

.card {
  border: 1px solid rgba(126, 169, 191, 0.12);
  background: linear-gradient(180deg, rgba(14, 20, 26, 0.96), rgba(8, 13, 18, 0.92));
}

.card .title,
.article .title,
.menu-label,
.footer,
.navbar {
  letter-spacing: .02em;
}

.menu-label {
  text-transform: uppercase;
  letter-spacing: .08em;
}

.card-content {
  background: transparent;
}

.article .content h1,
.article .content h2,
.article .content h3,
.article .content h4 {
  letter-spacing: .02em;
}

.article .content blockquote {
  background-color: rgba(210, 180, 140, 0.08);
  border-left: 3px solid #d2b48c;
  color: #f1e3cd;
}

.article .content pre,
.article .content code {
  font-family: $family-code;
}

.article .content pre {
  background: rgba(5, 10, 15, 0.94);
  border: 1px solid rgba(126, 169, 191, 0.14);
}

.tag:not(body) {
  background-color: rgba(126, 169, 191, 0.10);
  color: #d6dee4;
}

.menu-list a.is-active,
.menu-list a:hover,
.pagination-link.is-current {
  border-color: rgba(126, 169, 191, 0.24);
}

.navbar-end #night-nav {
  display: none;
}

.card-image img {
  object-fit: cover;
}

.post-copyright {
  border-left: 3px solid rgba(138, 214, 255, 0.4);
}

// 自定义图片样式
.img-x {
