.container {
  max-width: 1360px;
}

.section {
  padding-top: 2rem;
  padding-bottom: 3.5rem;
}

.navbar-main .navbar-container {
  align-items: center;
}

.navbar-main .navbar-logo {
  display: flex;
  align-items: center;
  gap: 0.9rem;
  padding-left: 0;
}

.navbar-brand-mark {
  width: 2.25rem;
  height: 2.25rem;
  border-radius: 0.7rem;
  border: 1px solid rgba(126, 169, 191, 0.18);
  background: rgba(10, 16, 22, 0.76);
}

.navbar-brand-text {
  display: flex;
  flex-direction: column;
  line-height: 1.1;
}

.navbar-brand-title {
  color: #f2f5f7;
  font-size: 0.98rem;
  font-weight: 600;
  letter-spacing: 0.04em;
}

.navbar-brand-subtitle {
  color: #90a0ad;
  font-size: 0.72rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.navbar-start .navbar-item,
.navbar-end .navbar-item {
  font-size: 0.92rem;
}

.navbar-start .navbar-item {
  position: relative;
  padding-inline: 0.85rem;
}

.navbar-start .navbar-item:after {
  content: '';
  position: absolute;
  left: 0.85rem;
  right: 0.85rem;
  bottom: 0.8rem;
  height: 1px;
  background: rgba(210, 180, 140, 0.6);
  transform: scaleX(0);
  transform-origin: left center;
  transition: transform 0.2s ease;
}

.navbar-start .navbar-item:hover:after,
.navbar-start .navbar-item.is-active:after {
  transform: scaleX(1);
}

.home-hero {
  overflow: hidden;
}

.home-hero-content {
  padding: 2.4rem 2.4rem 2rem;
}

.home-hero-grid {
  display: grid;
  grid-template-columns: minmax(0, 1.35fr) minmax(300px, 0.9fr);
  gap: 2rem;
  align-items: stretch;
}

.home-eyebrow,
.home-section-kicker,
.profile-eyebrow {
  margin-bottom: 0.9rem;
  color: #90a0ad;
  font-size: 0.74rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
}

.home-title {
  margin-bottom: 1rem !important;
  font-size: clamp(2rem, 5vw, 3.6rem);
  line-height: 1;
}

.home-subtitle {
  max-width: 44rem;
  margin-bottom: 1.4rem;
  font-size: 1.02rem;
  line-height: 1.75;
  color: #c7d1d8;
}

.home-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.8rem;
  margin-bottom: 1.8rem;
}

.home-action-primary,
.home-action-secondary,
.article-more.button {
  border-radius: 999px;
  padding-inline: 1.1rem;
  font-weight: 600;
}

.home-action-primary {
  background: linear-gradient(135deg, #7ea9bf, #96bbc8);
  color: #071018 !important;
}

.home-action-secondary,
.article-more.button {
  border: 1px solid rgba(126, 169, 191, 0.2);
  background: rgba(9, 14, 19, 0.72) !important;
  color: #f2f5f7 !important;
}

.home-stats {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 0.9rem;
}

.home-stat {
  padding: 1rem 1.1rem;
  border: 1px solid rgba(126, 169, 191, 0.12);
  border-radius: 1rem;
  background: rgba(6, 10, 14, 0.44);
}

.home-stat-value {
  display: block;
  color: #f2f5f7;
  font-size: 1.45rem;
  font-weight: 600;
}

.home-stat-label {
  color: #90a0ad;
  font-size: 0.82rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.home-hero-panel {
  position: relative;
  border: 1px solid rgba(126, 169, 191, 0.14);
  border-radius: 1.15rem;
  padding: 1.15rem 1.2rem;
  background: linear-gradient(180deg, rgba(7, 11, 15, 0.94), rgba(10, 16, 22, 0.78));
  overflow: hidden;
}

.home-hero-panel:before {
  content: '';
  position: absolute;
  inset: 0 auto auto 0;
  width: 100%;
  height: 3px;
  background: linear-gradient(90deg, #7ea9bf, #d2b48c, transparent);
}

.home-panel-title {
  margin-bottom: 1rem;
  color: #d2b48c;
  font-family: $family-code;
  font-size: 0.78rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
}

.home-panel-body {
  display: grid;
  gap: 0.7rem;
}

.home-panel-row {
  display: grid;
  grid-template-columns: 4.3rem minmax(0, 1fr);
  gap: 0.75rem;
  align-items: start;
  font-family: $family-code;
  font-size: 0.86rem;
}

.home-panel-key {
  color: #7ea9bf;
}

.home-panel-value {
  color: #d6dee4;
}

.home-panel-footer {
  margin-top: 1.4rem;
  padding-top: 1rem;
  border-top: 1px solid rgba(126, 169, 191, 0.12);
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}

.home-panel-label {
  color: #90a0ad;
  font-size: 0.74rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

.home-panel-footer a {
  color: #f2f5f7;
  font-weight: 600;
}

.home-panel-date {
